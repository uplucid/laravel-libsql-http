{
    "name": "uplucid/laravel-libsql-http",
    "description": "Pure PHP HTTP driver for Turso/libSQL in Laravel 11+",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Uplucid\\LibSql\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Uplucid\\LibSql\\LibSqlServiceProvider"
            ]
        }
    },
    "require": {
        "php": ">=8.2",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6"
    },
    "autoload-dev": {
        "psr-4": {
            "Uplucid\\LibSql\\Tests\\": "tests/"
        }
    }
}
